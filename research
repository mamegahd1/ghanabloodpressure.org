<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="The evidence base behind GHSI: peer-reviewed research on hypertension prevalence in Ghana, community screening methodologies, the Simple app platform, and WHO HEARTS technical guidance.">
    <meta property="og:title" content="Research & Evidence — GHSI">
    <meta property="og:description" content="The evidence base behind GHSI: peer-reviewed research on hypertension prevalence in Ghana, community screening methodologies, the Simple app platform, and WHO HEARTS technical guidance.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://ghanabloodpressure.org/research/">
    <meta property="og:site_name" content="Ghana Hypertension Screening Initiative">
    <link rel="canonical" href="https://ghanabloodpressure.org/research/">
    <title>Research | Ghana Hypertension Screening Initiative</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Playfair+Display:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
:root {
    --teal: #1A5F5F;
    --teal-dark: #134747;
    --teal-light: #238080;
    --burgundy-deep: #4A1525;
    --burgundy: #5D1A2E;
    --gold: #C9A227;
    --gold-light: #D4B84A;
    --gold-pale: #E8D590;
    --cream: #FDFAF5;
    --cream-dark: #F5EEE0;
    --charcoal: #2C2C2C;
    --charcoal-light: #4A4A4A;
    --white: #FFFFFF;
    --green: #2D8B2D;
    --yellow: #D4A017;
    --orange: #D97706;
    --red: #C53030;
    --darkred: #7B1818;
}

* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }

body {
    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
    background-color: var(--cream);
    color: var(--charcoal);
    line-height: 1.7;
    font-size: 17px;
}

h1, h2, h3, h4, h5 {
    font-family: 'Playfair Display', Georgia, 'Times New Roman', serif;
    font-weight: 700;
    line-height: 1.2;
}

.container { max-width: 1100px; margin: 0 auto; }

/* === COUNTDOWN BANNER === */
.countdown-banner {
    background: var(--teal);
    color: var(--white);
    text-align: center;
    padding: 0.65rem 1rem;
    font-size: 0.92rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    position: relative;
    z-index: 1001;
}
.countdown-banner a {
    color: var(--gold-pale);
    font-weight: 700;
    text-decoration: underline;
    margin-left: 0.5rem;
}
.countdown-banner a:hover { color: var(--gold); }
.countdown-banner strong { color: var(--gold-pale); font-size: 1.05rem; }

/* === NAVIGATION === */
.nav {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: var(--burgundy-deep);
    padding: 0.6rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0 2px 20px rgba(74, 21, 37, 0.3);
}
.nav-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
}
.nav-logo-text {
    color: var(--gold);
    font-family: 'Playfair Display', Georgia, 'Times New Roman', serif;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.02em;
}
.nav-links {
    display: flex;
    gap: 1.75rem;
    list-style: none;
    align-items: center;
}
.nav-links a {
    color: var(--cream);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    transition: color 0.3s ease;
    position: relative;
}
.nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--gold);
    transition: width 0.3s ease;
}
.nav-links a:hover { color: var(--gold); }
.nav-links a:hover::after { width: 100%; }
.nav-links a.active { color: var(--gold); }
.nav-links a.active::after { width: 100%; }
.nav-donate-btn {
    background: var(--gold);
    color: var(--burgundy-deep) !important;
    padding: 0.45rem 1.1rem;
    border-radius: 4px;
    font-weight: 700 !important;
    font-size: 0.85rem !important;
    text-decoration: none !important;
}
.nav-donate-btn:hover {
    background: var(--gold-light) !important;
    color: var(--burgundy-deep) !important;
}
.nav-donate-btn::after { display: none !important; }
.nav-mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
}
.nav-mobile-toggle span {
    display: block;
    width: 25px;
    height: 2px;
    background: var(--gold);
    margin: 5px 0;
    transition: 0.3s;
}

/* === SECTIONS === */
section { padding: 5rem 2rem; }
.section-header { text-align: center; margin-bottom: 3rem; }
.section-label {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--teal);
    margin-bottom: 0.75rem;
}
.section-title {
    font-size: 2.6rem;
    color: var(--burgundy-deep);
    margin-bottom: 1rem;
}
.section-intro {
    font-size: 1.1rem;
    color: var(--charcoal-light);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.8;
}

/* === BUTTONS === */
.btn {
    display: inline-block;
    padding: 0.9rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 4px;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
}
.btn-primary {
    background: var(--teal);
    color: var(--white);
}
.btn-primary:hover {
    background: var(--teal-dark);
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(26, 95, 95, 0.4);
}
.btn-secondary {
    background: transparent;
    color: var(--teal);
    border: 2px solid var(--teal);
}
.btn-secondary:hover {
    background: var(--teal);
    color: var(--white);
}
.btn-gold {
    background: var(--gold);
    color: var(--burgundy-deep);
    font-weight: 700;
}
.btn-gold:hover {
    background: var(--gold-light);
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(201, 162, 39, 0.4);
}

/* === STATS BAR === */
.stats-bar {
    background: var(--burgundy-deep);
    padding: 3rem 2rem;
}
.stats-container {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
}
.stat-item { text-align: center; color: var(--cream); }
.stat-number {
    font-family: 'Playfair Display', Georgia, 'Times New Roman', serif;
    font-size: 3.2rem;
    font-weight: 700;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 0.5rem;
}
.stat-label { font-size: 1rem; font-weight: 500; color: var(--cream); }
.stat-source { font-size: 0.8rem; color: #C5BBAB; margin-top: 0.5rem; }
.stat-source a { color: var(--gold-pale); text-decoration: none; }
.stat-source a:hover { text-decoration: underline; }

/* === CARDS === */
.card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
}
.card {
    background: var(--white);
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    border-top: 4px solid var(--teal);
    transition: transform 0.3s ease;
}
.card:hover { transform: translateY(-4px); }
.card h3, .card h4 {
    color: var(--burgundy-deep);
    margin-bottom: 0.75rem;
}
.card p {
    color: var(--charcoal-light);
    line-height: 1.7;
}

/* === PILLAR CARDS === */
.pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
}
.pillar-card {
    background: var(--white);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    transition: transform 0.3s ease;
}
.pillar-card:hover { transform: translateY(-4px); }
.pillar-header {
    background: var(--teal);
    color: var(--white);
    padding: 1.5rem;
    text-align: center;
}
.pillar-number {
    font-family: 'Playfair Display', Georgia, 'Times New Roman', serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--gold-pale);
    margin-bottom: 0.25rem;
}
.pillar-title { color: var(--white); font-size: 1.3rem; }
.pillar-subtitle { font-size: 0.85rem; color: var(--cream-dark); margin-top: 0.25rem; }
.pillar-content { padding: 1.5rem; }
.pillar-content p { margin-bottom: 1rem; color: var(--charcoal-light); }
.pillar-list {
    list-style: none;
    padding: 0;
}
.pillar-list li {
    padding: 0.4rem 0 0.4rem 1.5rem;
    position: relative;
    color: var(--charcoal-light);
    font-size: 0.95rem;
}
.pillar-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--teal);
    font-weight: 700;
}

/* === IMAGE SECTIONS === */
.hero-image-section {
    position: relative;
    overflow: hidden;
}
.hero-image-section img {
    width: 100%;
    height: 500px;
    object-fit: cover;
    display: block;
}
.hero-image-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(74, 21, 37, 0.85));
    padding: 3rem 2rem 2rem;
    color: var(--white);
}
.hero-image-overlay h1 {
    font-size: 3rem;
    color: var(--white);
    margin-bottom: 0.75rem;
}
.hero-image-overlay p {
    font-size: 1.15rem;
    color: var(--cream);
    max-width: 700px;
}

/* === SECTION IMAGE (side by side) === */
.split-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    max-width: 1100px;
    margin: 0 auto;
}
.split-section img {
    width: 100%;
    border-radius: 12px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
    object-fit: cover;
    height: 400px;
}
.split-section .content h2 {
    font-size: 2.2rem;
    color: var(--burgundy-deep);
    margin-bottom: 1rem;
}
.split-section .content p {
    color: var(--charcoal-light);
    line-height: 1.8;
    margin-bottom: 1rem;
}

/* === BP COLOR SYSTEM === */
.bp-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.75rem;
    margin-top: 2rem;
}
.bp-tier {
    padding: 1.25rem 0.75rem;
    border-radius: 10px;
    text-align: center;
    color: var(--white);
    font-size: 0.85rem;
}
.bp-tier .bp-label {
    font-family: 'Playfair Display', Georgia, 'Times New Roman', serif;
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
}
.bp-tier .bp-range { font-size: 0.8rem; margin-bottom: 0.4rem; }
.bp-tier .bp-action { font-size: 0.78rem; font-weight: 600; }

/* === CLOSED LOOP VISUAL === */
.loop-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
    margin-top: 2rem;
}
.loop-item {
    background: rgba(255,255,255,0.1);
    padding: 1.5rem;
    border-radius: 8px;
    text-align: center;
}
.loop-number {
    font-family: 'Playfair Display', Georgia, 'Times New Roman', serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--gold);
}
.loop-unit { font-size: 0.9rem; color: #E6E0D2; }
.loop-question { margin-top: 0.75rem; font-size: 0.85rem; }

/* === TIMELINE === */
.timeline {
    display: flex;
    justify-content: space-between;
    position: relative;
    margin-top: 3rem;
    padding: 0 1rem;
}
.timeline::before {
    content: '';
    position: absolute;
    top: 28px;
    left: 5%;
    right: 5%;
    height: 4px;
    background: var(--teal);
    border-radius: 2px;
}
.timeline-item {
    text-align: center;
    position: relative;
    flex: 1;
    padding: 0 0.5rem;
}
.timeline-dot {
    width: 56px;
    height: 56px;
    background: var(--teal);
    border-radius: 50%;
    margin: 0 auto 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
    font-weight: 700;
    font-size: 0.8rem;
    position: relative;
    z-index: 1;
    border: 3px solid var(--cream);
}
.timeline-label {
    font-weight: 700;
    color: var(--burgundy-deep);
    font-size: 0.95rem;
    margin-bottom: 0.25rem;
}
.timeline-desc {
    font-size: 0.82rem;
    color: var(--charcoal-light);
    max-width: 130px;
    margin: 0 auto;
}

/* === TEAM === */
.team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
}
.team-card {
    background: var(--white);
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    text-align: center;
    border-top: 4px solid var(--teal);
}
.team-card h4 {
    color: var(--burgundy-deep);
    font-size: 1.2rem;
    margin-bottom: 0.25rem;
}
.team-role {
    color: var(--teal);
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 0.25rem;
}
.team-location {
    color: var(--charcoal-light);
    font-size: 0.85rem;
    margin-bottom: 1rem;
}
.team-bio {
    color: var(--charcoal-light);
    font-size: 0.95rem;
    line-height: 1.7;
}

/* === PARTNER CARDS === */
.partner-card {
    background: var(--white);
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    border-left: 4px solid var(--gold);
}
.partner-card h4 {
    color: var(--burgundy-deep);
    font-size: 1.15rem;
    margin-bottom: 0.25rem;
}
.partner-type {
    color: var(--teal);
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 1rem;
}
.partner-card p {
    color: var(--charcoal-light);
    line-height: 1.7;
    font-size: 0.95rem;
}
.partner-card a {
    color: var(--teal);
    text-decoration: none;
    font-weight: 600;
}
.partner-card a:hover { text-decoration: underline; }

/* === CONTACT FORM === */
.contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    max-width: 1000px;
    margin: 0 auto;
}
.contact-info h3 {
    color: var(--burgundy-deep);
    margin-bottom: 1.5rem;
}
.contact-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: 1.5rem;
}
.contact-icon { font-size: 1.5rem; }
.contact-item a { color: var(--teal); text-decoration: none; }
.contact-item a:hover { text-decoration: underline; }
.form-group { margin-bottom: 1.25rem; }
.form-group label {
    display: block;
    margin-bottom: 0.4rem;
    font-weight: 600;
    color: var(--charcoal);
    font-size: 0.95rem;
}
.form-group input,
.form-group select,
.form-group textarea {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-family: inherit;
    font-size: 1rem;
    transition: border-color 0.3s;
}
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
    outline: none;
    border-color: var(--teal);
}

/* === FOOTER === */
.footer {
    background: var(--burgundy-deep);
    color: var(--cream);
    padding: 3rem 2rem 1.5rem;
}
.footer-content {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 2rem;
}
.footer-brand p {
    max-width: 350px;
    
    font-size: 0.95rem;
    line-height: 1.6;
    margin-top: 0.75rem;
}
.footer h4 {
    color: var(--gold);
    font-size: 1rem;
    margin-bottom: 1rem;
}
.footer ul {
    list-style: none;
}
.footer ul li { margin-bottom: 0.5rem; }
.footer ul li a {
    color: var(--cream);
    text-decoration: none;
    color: #C5BBAB;
    font-size: 0.9rem;
    transition: color 0.3s;
}
.footer ul li a:hover { color: var(--cream); }
.footer-bottom {
    max-width: 1100px;
    margin: 2rem auto 0;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.15);
    text-align: center;
    font-size: 0.85rem;
    color: #B0A88F;
}

/* === DARK SECTION === */
.dark-section {
    background: var(--burgundy-deep);
    color: var(--cream);
}
.dark-section .section-label { color: var(--gold-pale); }
.dark-section .section-title { color: var(--gold); }
.dark-section .section-intro { color: #E6E0D2; }

.teal-section {
    background: var(--teal);
    color: var(--white);
}
.teal-section .section-label { color: var(--gold-pale); }
.teal-section .section-title { color: var(--white); }
.teal-section .section-intro { color: #E6E0D2; }

/* === DONATE CTA === */
.donate-cta {
    background: linear-gradient(135deg, var(--teal) 0%, var(--teal-dark) 100%);
    padding: 4rem 2rem;
    text-align: center;
    color: var(--white);
}
.donate-cta h2 {
    color: var(--white);
    font-size: 2.2rem;
    margin-bottom: 1rem;
}
.donate-cta p {
    color: var(--cream);
    max-width: 600px;
    margin: 0 auto 2rem;
    font-size: 1.1rem;
    color: #E6E0D2;
}

/* === OPEN ROLES === */
.roles-list { margin-top: 1.5rem; }
.role-item {
    background: var(--cream);
    padding: 1.25rem 1.5rem;
    border-radius: 8px;
    margin-bottom: 0.75rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.role-item strong { color: var(--burgundy-deep); }
.role-item span { color: var(--charcoal-light); font-size: 0.9rem; }

/* === RESPONSIVE === */

/* === ACCESSIBILITY: Focus styles === */
a:focus-visible,
button:focus-visible,
input:focus-visible,
select:focus-visible,
textarea:focus-visible {
    outline: 3px solid var(--gold);
    outline-offset: 2px;
}

/* === ACCESSIBILITY: Skip navigation === */
.skip-nav {
    position: absolute;
    top: -100%;
    left: 50%;
    transform: translateX(-50%);
    background: var(--gold);
    color: var(--burgundy-deep);
    padding: 0.75rem 1.5rem;
    font-weight: 700;
    font-size: 0.95rem;
    z-index: 2000;
    border-radius: 0 0 6px 6px;
    text-decoration: none;
}
.skip-nav:focus {
    top: 0;
}

/* === TOUCH TARGETS: Nav links === */
.nav-links a {
    padding: 0.6rem 0.25rem;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
}


@media (max-width: 1024px) and (min-width: 769px) {
    .stats-container { grid-template-columns: repeat(2, 1fr); }
    .split-section { gap: 2rem; }
    .team-grid { grid-template-columns: repeat(2, 1fr); }
    .card-grid { grid-template-columns: repeat(2, 1fr); }
    section { padding: 4rem 2rem; }
    .section-title { font-size: 2.3rem; }
    .hero-image-overlay h1 { font-size: 2.5rem; }
}

@media (max-width: 768px) {
    .nav-links {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: var(--burgundy-deep);
        flex-direction: column;
        padding: 1rem 2rem;
        gap: 0.75rem;
    }
    .nav-links.active { display: flex; }
    .nav-mobile-toggle { display: block; }
    .hero-image-section img { height: 300px; }
    .hero-image-overlay h1 { font-size: 2rem; }
    .stats-container { grid-template-columns: 1fr; gap: 1.5rem; }
    .pillars-grid { grid-template-columns: 1fr; }
    .split-section { grid-template-columns: 1fr; }
    .bp-grid { grid-template-columns: repeat(2, 1fr); }
    .loop-grid { grid-template-columns: repeat(2, 1fr); }
    .timeline { flex-wrap: wrap; gap: 2rem; }
    .timeline::before { display: none; }
    .contact-grid { grid-template-columns: 1fr; }
    .footer-content { grid-template-columns: 1fr; text-align: center; }
    .footer-brand p { max-width: none; }
    section { padding: 3rem 1.5rem; }
    .section-title { font-size: 2rem; }
    .team-grid { grid-template-columns: 1fr; }
}

@keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}
.animate-in { animation: fadeInUp 0.5s ease forwards; }

/* === RESEARCH PAGE SPECIFIC === */
.research-hero {
    background: var(--burgundy-deep);
    color: var(--cream);
    padding: 4rem 2rem;
    text-align: center;
}
.research-hero h1 {
    font-size: 2.8rem;
    color: var(--white);
    margin-bottom: 1rem;
}
.research-hero p {
    font-size: 1.15rem;
    color: var(--cream);
    max-width: 750px;
    margin: 0 auto;
    line-height: 1.8;
